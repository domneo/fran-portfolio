{
  "name": "fran-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tinacms dev -c \"next dev\"",
    "build": "tinacms build && next build",
    "start": "tinacms build && next start",
    "lint": "next lint",
    "prepare": "husky install",
    "prettier": "prettier --write . --ignore-path .prettierignore",
    "pretty-quick": "pretty-quick --staged --ignore-path .prettierignore"
  },
  "dependencies": {
    "@georgedoescode/spline": "^1.0.1",
    "@tinacms/cli": "^1.5.39",
    "@vercel/analytics": "^1.1.3",
    "@vercel/speed-insights": "^1.0.9",
    "bootstrap": "^5.3.2",
    "classnames": "^2.5.1",
    "gsap": "^3.12.5",
    "next": "14.1.0",
    "next-password-protect": "^1.8.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-modal": "^3.16.1",
    "react-slick": "^0.30.1",
    "react-string-replace": "^1.1.1",
    "simplex-noise": "^4.0.1",
    "slick-carousel": "^1.8.1",
    "string-remove-widows": "^4.0.20",
    "tinacms": "^1.5.28"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/node": "^20.11.17",
    "@types/react": "^18.2.55",
    "@types/react-modal": "^3.16.3",
    "@types/react-slick": "^0.23.13",
    "@types/uuid": "^9.0.8",
    "eslint": "8.56.0",
    "eslint-config-next": "14.1.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.0.10",
    "prettier": "^3.2.5",
    "pretty-quick": "^4.0.0",
    "sass": "^1.70.0",
    "typescript": "^5.3.3"
  },
  "prettier": {
    "quoteProps": "consistent",
    "importOrder": [
      "^(utils|query|styles|hooks)",
      "^(components)",
      "^[./]",
      "^(types)"
    ],
    "importOrderSeparation": true,
    "experimentalBabelParserPluginsList": [
      "jsx",
      "typescript"
    ]
  },
  "eslintConfig": {
    "extends": [
      "next",
      "prettier"
    ]
  }
}
