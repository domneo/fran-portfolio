{
  "name": "fran-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tinacms dev -c \"NODE_OPTIONS='--inspect' next dev\"",
    "build": "tinacms build && next build",
    "start": "tinacms build && next start",
    "lint": "next lint",
    "prepare": "husky install",
    "prettier": "prettier --write . --ignore-path .gitignore",
    "pretty-quick": "pretty-quick --staged --ignore-path .gitignore"
  },
  "dependencies": {
    "@georgedoescode/spline": "^1.0.1",
    "@tinacms/cli": "^1.5.30",
    "bootstrap": "^5.3.2",
    "classnames": "^2.3.2",
    "gsap": "^3.12.2",
    "next": "13.5.4",
    "next-password-protect": "^1.8.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-modal": "^3.16.1",
    "react-slick": "^0.29.0",
    "react-string-replace": "^1.1.1",
    "react-zoom-pan-pinch": "^3.2.0",
    "simplex-noise": "^4.0.1",
    "slick-carousel": "^1.8.1",
    "string-remove-widows": "^4.0.17",
    "tinacms": "^1.5.21"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^4.2.0",
    "@types/node": "^20.8.6",
    "@types/react": "^18.2.28",
    "@types/react-modal": "^3.16.1",
    "@types/react-slick": "^0.23.10",
    "@types/uuid": "^9.0.5",
    "eslint": "8.51.0",
    "eslint-config-next": "13.5.4",
    "eslint-config-prettier": "^8.8.0",
    "husky": "^8.0.3",
    "prettier": "^2.8.8",
    "pretty-quick": "^3.1.3",
    "sass": "^1.69.3",
    "typescript": "^5.2.2"
  },
  "prettier": {
    "quoteProps": "consistent",
    "importOrder": [
      "^(utils|query|styles|hooks)",
      "^(components)",
      "^[./]",
      "^(types)"
    ],
    "importOrderSeparation": true,
    "experimentalBabelParserPluginsList": [
      "jsx",
      "typescript"
    ]
  },
  "eslintConfig": {
    "extends": [
      "next",
      "prettier"
    ]
  }
}
