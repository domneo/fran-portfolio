{
  "name": "fran-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tinacms dev -c \"next dev\"",
    "build": "tinacms build && next build",
    "start": "tinacms build && next start",
    "lint": "next lint",
    "prepare": "husky",
    "prettier": "prettier --write . --ignore-path .prettierignore",
    "pretty-quick": "pretty-quick --staged --ignore-path .prettierignore"
  },
  "dependencies": {
    "@georgedoescode/spline": "^1.0.1",
    "@tinacms/cli": "^1.10.1",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "bootstrap": "^5.3.7",
    "classnames": "^2.5.1",
    "gsap": "^3.13.0",
    "next": "^15.5.14",
    "next-password-protect": "^1.8.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-modal": "^3.16.3",
    "react-slick": "^0.30.3",
    "react-string-replace": "^1.1.1",
    "simplex-noise": "^4.0.3",
    "slick-carousel": "^1.8.1",
    "string-remove-widows": "^4.0.25",
    "tinacms": "^2.8.1"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^24.0.14",
    "@types/react": "^18.2.55",
    "@types/react-modal": "^3.16.3",
    "@types/react-slick": "^0.23.13",
    "@types/uuid": "^10.0.0",
    "eslint": "8.56.0",
    "eslint-config-next": "14.1.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "pretty-quick": "^4.2.2",
    "sass": "1.70.0",
    "typescript": "5.8.3"
  },
  "prettier": {
    "quoteProps": "consistent",
    "importOrder": [
      "^(utils|query|styles|hooks)",
      "^(components)",
      "^[./]",
      "^(types)"
    ],
    "importOrderSeparation": true,
    "experimentalBabelParserPluginsList": [
      "jsx",
      "typescript"
    ]
  },
  "eslintConfig": {
    "extends": [
      "next",
      "prettier"
    ]
  }
}
