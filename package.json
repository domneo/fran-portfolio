{
  "name": "fran-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--inspect' next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "prepare": "husky install",
    "prettier": "prettier --write . --ignore-path .gitignore",
    "pretty-quick": "pretty-quick --staged --ignore-path .gitignore"
  },
  "dependencies": {
    "bootstrap": "^5.1.3",
    "next": "12.1.6",
    "react": "18.1.0",
    "react-dom": "18.1.0",
    "rfs": "^9.0.6"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^3.2.0",
    "@types/node": "^17.0.36",
    "@types/react": "^18.0.9",
    "eslint": "8.16.0",
    "eslint-config-next": "12.1.6",
    "eslint-config-prettier": "^8.5.0",
    "husky": "^8.0.1",
    "prettier": "^2.6.2",
    "pretty-quick": "^3.1.3",
    "sass": "^1.52.1",
    "typescript": "^4.7.2"
  },
  "prettier": {
    "quoteProps": "consistent",
    "importOrder": [
      "^(utils|query|styles|hooks)",
      "^(components)",
      "^[./]",
      "^(types)"
    ],
    "importOrderSeparation": true,
    "experimentalBabelParserPluginsList": [
      "jsx",
      "typescript"
    ]
  },
  "eslintConfig": {
    "extends": [
      "next",
      "prettier"
    ]
  }
}
